# Supabase — find these in your Supabase project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Dashboard password — set to any strong password for the demo login gate
DASHBOARD_DEMO_PASSWORD=your-secure-password

# Demo restaurant slug — must match the `slug` column in your restaurants table
NEXT_PUBLIC_DEMO_RESTAURANT_SLUG=your-restaurant-slug

# Public URL of the deployed app (used to generate QR code links)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Resend — find your API key at resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Email address that receives new guest issue notifications
NOTIFY_EMAIL=you@example.com

# Sender address for notification emails (must be a verified Resend domain)
RESEND_FROM_EMAIL=notifications@yourdomain.com

# Shared secret that gates /api/notify from direct external callers (server-only)
NOTIFY_INTERNAL_TOKEN=your-random-secret-token
